## Padrões de componentes

### Novo componente de página
```tsx
// src/app/(dashboard)/nova-rota/page.tsx
import { auth } from "@/lib/auth"
import { db } from "@/lib/db"
import { redirect } from "next/navigation"
import { NomeView } from "@/components/nome/nome-view"

export default async function NomePage() {
  const session = await auth()
  if (!session?.user?.id) redirect("/login")

  const data = await db.modelo.findMany({ where: { userId: session.user.id } })
  return <NomeView initialData={data} />
}
```

### Componente cliente com SWR
```tsx
"use client"
import useSWR from "swr"

// NÃO faça:
// const fetcher = (url) => fetch(url).then(r => r.json())
// useSWR(key, fetcher)

// FAÇA (usa o fetcher global do SWRProvider):
const { data } = useSWR<TipoCorreto>("/api/rota")
```

### Formulário com mutação
```tsx
async function handleSubmit() {
  const res = await fetch("/api/rota", { method: "POST", ... })
  const json = await res.json()
  if (!res.ok) { toast.error(json.error ?? "Erro"); return }
  toast.success("Salvo!")
  revalidate() // mutate do useSWR local
  globalMutate("/api/outro-recurso") // se necessário
}
```

